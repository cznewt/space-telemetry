# space-telemetry configuration (all fields optional; see docs/configuration.md).
# Every field is SPACE_TELEMETRY_<FIELD>. A YAML file (space-telemetry.yaml, or
# $SPACE_TELEMETRY_CONFIG) is an alternative — env overrides YAML overrides defaults.

# Observer (defaults to Prague). For several sites use a YAML `observers:` list, or
# SPACE_TELEMETRY_OBSERVERS='[{"name":"prague","latitude_deg":50.07,"longitude_deg":14.44}]'
SPACE_TELEMETRY_OBSERVER_NAME=prague
SPACE_TELEMETRY_OBSERVER_LAT=50.0755
SPACE_TELEMETRY_OBSERVER_LON=14.4378
SPACE_TELEMETRY_OBSERVER_ELEVATION_M=200

# Sky — solar-system bodies + celestial bodies (stars), comma separated
SPACE_TELEMETRY_BODIES=sun,moon,mercury,venus,mars,jupiter,saturn
SPACE_TELEMETRY_STARS=sirius,vega,arcturus,capella,rigel,betelgeuse,aldebaran,polaris
SPACE_TELEMETRY_MIN_ELEVATION_DEG=0

# Satellites (CelesTrak orbits + SatNOGS transmitters)
SPACE_TELEMETRY_SAT_ENABLED=true
SPACE_TELEMETRY_SAT_GROUPS=stations
SPACE_TELEMETRY_SAT_WATCHLIST=25544
SPACE_TELEMETRY_TLE_REFRESH_HOURS=8

# Space weather (NOAA SWPC)
SPACE_TELEMETRY_SPACE_WEATHER_ENABLED=true
SPACE_TELEMETRY_SPACE_WEATHER_REFRESH_MINUTES=5

# Offline ephemeris kernel + where cached data lives
SPACE_TELEMETRY_EPHEMERIS=de421.bsp
SPACE_TELEMETRY_CACHE_DIR=data

# Serving
SPACE_TELEMETRY_HOST=0.0.0.0
SPACE_TELEMETRY_PORT=9110
# SPACE_TELEMETRY_OTLP_ENDPOINT=http://localhost:4317
