{
  "uid": "sky-overview",
  "title": "Space Telemetry",
  "tags": ["space-telemetry"],
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Moon illuminated",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "moon_illuminated_fraction", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "justifyMode": "auto" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Moon phase",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "moon_phase_degrees", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "degree", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto", "justifyMode": "auto" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Bodies above horizon",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(body_above_horizon)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto", "justifyMode": "auto" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Satellites tracked",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "satellite_tracked_count", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto", "justifyMode": "auto" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Body altitude (°)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "body_altitude_degrees", "legendFormat": "{{body}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "degree", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 8, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Body azimuth (°)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "body_azimuth_degrees", "legendFormat": "{{body}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "degree", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 0, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "none" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "ISS elevation (°)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "satellite_elevation_degrees{name=~\"ISS.*\"}", "legendFormat": "{{name}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "degree", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 8, "showPoints": "never" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 0 } ] } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "none" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "ISS altitude (km)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "satellite_altitude_meters{name=~\"ISS.*\"} / 1000", "legendFormat": "{{name}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "lengthkm", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 8, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Source data age (s)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "satellite_data_age_seconds", "legendFormat": "{{source}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 0, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "none" } }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Sources healthy",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(satellite_data_update_success)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto", "justifyMode": "auto" }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Catalog size",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "satellite_catalog_size", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto", "justifyMode": "auto" }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Kp index",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "space_weather_planetary_k_index", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1, "min": 0, "max": 9, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 7 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "auto", "justifyMode": "auto" }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Solar wind (km/s)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "space_weather_solar_wind_speed_km_per_second", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "justifyMode": "auto" }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "IMF Bz (nT)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "space_weather_imf_bz_nanotesla", "legendFormat": "Bz", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "GOES X-ray flux (W/m²)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "space_weather_goes_xray_flux_watts_per_m2", "legendFormat": "0.1-0.8 nm", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 0, "showPoints": "never", "scaleDistribution": { "type": "log", "log": 10 } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Star altitude (°)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "star_altitude_degrees", "legendFormat": "{{star}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "degree", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 0, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "none" } }
    }
  ]
}
